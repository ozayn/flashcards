# Environment configuration template
# Copy this file to .env and fill in real values

# Environment: development (default) or production. In production, /docs, /redoc, /openapi.json are disabled.
ENVIRONMENT=development

# Admin API key. Required for /protected-ping. Use X-Admin-Api-Key header.
ADMIN_API_KEY=your-secret-key

GROQ_API_KEY=your_value_here
