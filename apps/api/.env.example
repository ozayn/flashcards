# Environment configuration template
# Copy this file to .env and fill in real values

# Environment: development (default) or production. In production, /docs, /redoc, /openapi.json require admin auth.
ENVIRONMENT=development

# Admin API key. Required for /protected-ping and for docs in production. Use X-Admin-Api-Key header, or /docs-auth (form or header) for browser.
ADMIN_API_KEY=your-secret-key

# Comma-separated emails allowed to call /admin/* (must match apps/web ADMIN_EMAILS).
# Gmail/googlemail: dots and +tags are ignored for matching (see app/core/email_identity.py).
ADMIN_EMAILS=

# /admin API: valid acting-user HMAC from Next.js proxy + backend User.email in ADMIN_EMAILS.

# Next.js Google sign-in: server calls POST /users/oauth/google with header X-Memo-OAuth-Secret.
# Must match MEMO_OAUTH_SYNC_SECRET in apps/web/.env.local (use a long random string).
MEMO_OAUTH_SYNC_SECRET=

# Google sign-in allowlist (comma-separated, trim, case-insensitive). Must match apps/web ALLOWED_LOGIN_EMAILS.
# If empty or unset, POST /users/oauth/google rejects all (no new/updated OAuth users).
ALLOWED_LOGIN_EMAILS=

# LLM provider (groq, openai, etc.)
LLM_PROVIDER=groq

# Groq API (optional extra keys: comma-separated, tried after GROQ_API_KEY on rate limits / transient errors only)
GROQ_API_KEY=your_value_here
# GROQ_API_KEYS=key2,key3
GROQ_MODEL=llama-3.1-8b-instant
# Optional: route Groq API traffic only through this proxy (e.g. same Webshare URL as YOUTUBE_PROXY_URL).
# httpx uses trust_env=False so HTTP_PROXY/HTTPS_PROXY are still ignored; only this explicit URL applies.
# GROQ_PROXY_URL=http://user:pass@host:port
# LLM calls ignore HTTP_PROXY/HTTPS_PROXY/ALL_PROXY. OpenAI stays direct unless you add a similar knob.
# Use YOUTUBE_PROXY_URL / WEBSHARE_* for YouTube transcripts; GROQ_PROXY_URL is Groq-only.

# OpenAI (disabled by default; set OPENAI_ENABLED=1 to use as fallback)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_ENABLED=0

# OpenRouter (for test scripts)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-3.5-turbo

# Together AI (for test scripts)
TOGETHER_API_KEY=
TOGETHER_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct-Turbo

# Gemini (for test scripts)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Ollama (for test scripts, local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Optional tuning
LLM_TEMPERATURE=0.2
# Max output tokens (floor 1500; default 2048). Raise for large flashcard batches.
LLM_MAX_TOKENS=2048

# Gemini: avoid GEMINI_USE_TRIPLE_NEWLINE_STOP=1 — it can truncate pretty-printed JSON.
# GEMINI_USE_TRIPLE_NEWLINE_STOP=0
# GEMINI_MAX_OUTPUT_TOKENS_CAP=8192
# GEMINI_TRUNCATION_RETRY_MIN_TOKENS=4096

# Cost tracking (1=on, 0=off). Logs token usage and estimated API costs.
LLM_COST_TRACKING=1

# --- YouTube transcript proxy (optional) ---
# The API loads apps/api/.env then apps/api/app/.env (both if present; later file wins on duplicate keys).
# Generic HTTPS proxy URL (user:pass@host:port supported; never commit real credentials).
# YOUTUBE_PROXY_URL=http://127.0.0.1:8888
# Additional proxies (comma, pipe, or newline separated). Tried after YOUTUBE_PROXY_URL when the first fails with block/network errors.
# YOUTUBE_PROXY_URLS=http://backup-proxy:8888,http://other:8888
# Webshare rotating residential (alternative to YOUTUBE_PROXY_URL):
# WEBSHARE_PROXY_USER=
# WEBSHARE_PROXY_PW=
# Optional: preferred caption languages (comma-separated). Defaults try en then any available (e.g. fa).
# YOUTUBE_TRANSCRIPT_LANGUAGES=en,fa
# Egress verification: non-blocking after API startup. Default YOUTUBE_PROXY_VERIFY_EGRESS=off when
# ENVIRONMENT is not production; in production it defaults on (set to 0 to skip). When enabled, checks
# run in a background thread in parallel (not sequential). On-demand: POST /youtube/proxy-verify-egress (admin key).
# YOUTUBE_PROXY_VERIFY_EGRESS=1
# Optional: override IP echo URL (must return plain-text IP as first line). Default https://api.ipify.org
# YOUTUBE_PROXY_IP_ECHO_URL=https://api.ipify.org
# Per-request timeout (seconds) for each parallel egress probe. Default 5.
# YOUTUBE_PROXY_EGRESS_TIMEOUT=5
# Max parallel workers for egress checks (capped by proxy count). Default 8.
# YOUTUBE_PROXY_EGRESS_MAX_WORKERS=8
