# Environment configuration template
# Copy this file to .env and fill in real values

# Environment: development (default) or production. In production, /docs, /redoc, /openapi.json require admin auth.
ENVIRONMENT=development

# Admin API key. Required for /protected-ping and for docs in production. Use X-Admin-Api-Key header, or /docs-auth (form or header) for browser.
ADMIN_API_KEY=your-secret-key

GROQ_API_KEY=your_value_here
