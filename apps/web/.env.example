# Public API URL (for display; client calls go via /api/proxy)
NEXT_PUBLIC_API_URL=http://localhost:8080

# App URL (Open Graph, etc.). Must match where the web app is served for Google OAuth redirects.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# NextAuth (Google sign-in). Generate NEXTAUTH_SECRET with: openssl rand -base64 32
# NEXTAUTH_URL must be the origin users hit in the browser (e.g. https://your-app.vercel.app).
# Sign-in page requires (web runtime): GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET, NEXTAUTH_SECRET,
# MEMO_OAUTH_SYNC_SECRET. Use SIGNIN_GOOGLE_ENV_DEBUG=1 for one log line: present=true/false each (no secrets).
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
# SIGNIN_GOOGLE_ENV_DEBUG=1

# Google OAuth (create credentials at https://console.cloud.google.com/apis/credentials — Web application).
# Authorized redirect URI: {NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Shared secret with the API: POST /users/oauth/google. Must match MEMO_OAUTH_SYNC_SECRET in apps/api/.env
MEMO_OAUTH_SYNC_SECRET=

# Google sign-in allowlist (comma-separated, trim, case-insensitive). Must match apps/api ALLOWED_LOGIN_EMAILS.
# If empty or unset, no Google accounts can complete sign-in.
ALLOWED_LOGIN_EMAILS=

# Server-only: Railway private networking. Set on web service. Use BACKEND service name.
# API_INTERNAL_URL=http://${{api.RAILWAY_PRIVATE_DOMAIN}}:8080
# API_INTERNAL_URL=

# Comma-separated emails allowed to open /admin (must match API ADMIN_EMAILS).
# Gmail/googlemail: dots and +tags are ignored for matching (see email-identity.ts).
ADMIN_EMAILS=

# /admin: sign in with Google + email in ADMIN_EMAILS (no separate admin password).
