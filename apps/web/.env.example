# Public API URL (for display; client calls go via /api/proxy)
NEXT_PUBLIC_API_URL=http://localhost:8080

# App URL (Open Graph, etc.). Must match where the web app is served for Google OAuth redirects.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# NextAuth (Google sign-in). Generate NEXTAUTH_SECRET with: openssl rand -base64 32
# NEXTAUTH_URL must be the origin users hit in the browser (e.g. https://your-app.vercel.app).
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Google OAuth (create credentials at https://console.cloud.google.com/apis/credentials — Web application).
# Authorized redirect URI: {NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Shared secret with the API: POST /users/oauth/google. Must match MEMO_OAUTH_SYNC_SECRET in apps/api/.env
MEMO_OAUTH_SYNC_SECRET=

# Server-only: Railway private networking. Set on web service. Use BACKEND service name.
# API_INTERNAL_URL=http://${{api.RAILWAY_PRIVATE_DOMAIN}}:8080
# API_INTERNAL_URL=

# Password gate for /admin (POST /api/admin/unlock). Must match apps/api ADMIN_PAGE_PASSWORD (HMAC signing secret for admin API token).
ADMIN_PAGE_PASSWORD=change-me-admin-password
