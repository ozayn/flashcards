# Public API URL (for display; client calls go via /api/proxy)
NEXT_PUBLIC_API_URL=http://localhost:8080

# Server-only: Railway private networking. Set on web service. Use BACKEND service name.
# API_INTERNAL_URL=http://${{api.RAILWAY_PRIVATE_DOMAIN}}:8080
# API_INTERNAL_URL=

# Password gate for /admin (POST /api/admin/unlock). Must match apps/api ADMIN_PAGE_PASSWORD (HMAC signing secret for admin API token).
ADMIN_PAGE_PASSWORD=change-me-admin-password
