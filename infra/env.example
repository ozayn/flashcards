# =============================================================================
# Railway Deployment - Environment Variables
# =============================================================================
# Set these in Railway Dashboard: Project > Service > Variables
# =============================================================================

# -----------------------------------------------------------------------------
# API Service (apps/api)
# -----------------------------------------------------------------------------
# Required: PostgreSQL connection. Add Postgres plugin to get this automatically.
DATABASE_URL=postgresql://user:password@host:port/database

# Optional: Force port 8080. Dockerfile defaults to 8080; set if Railway uses different default.
# PORT=8080

# Optional: For future LLM features (flashcard generation, etc.)
# OPENAI_API_KEY=sk-...

# -----------------------------------------------------------------------------
# Web Service (apps/web)
# -----------------------------------------------------------------------------
# Required: Public API URL (for display; client calls go via /api/proxy).
# Use Railway's public URL: https://your-api.up.railway.app
NEXT_PUBLIC_API_URL=https://your-api.up.railway.app

# Optional: Stripe Payment Link for optional project support (must be set at web build time).
# NEXT_PUBLIC_MEMONEXT_SUPPORT_URL=https://buy.stripe.com/...

# Optional: Signed-out guest trial — UUID must match API-seeded guest user (see apps/api app.core.guest_trial).
# NEXT_PUBLIC_GUEST_TRIAL_USER_ID=a0000000-0000-4000-8000-000000000001

# Optional: Railway private networking. Set on WEB service only. Use BACKEND service name.
# Format: http://${{BACKEND_SERVICE_NAME.RAILWAY_PRIVATE_DOMAIN}}:8080
# Example: if your API service is named "api", use:
# API_INTERNAL_URL=http://${{api.RAILWAY_PRIVATE_DOMAIN}}:8080
# Do NOT use the web/frontend service name. Must be http (not https).

# Note: NEXT_PUBLIC_* must be set at build time. API_INTERNAL_URL is runtime-only.
